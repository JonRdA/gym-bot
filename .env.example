# --- Bot config (read by pydantic-settings) ---
GYMBOT_TELEGRAM_TOKEN=your-telegram-bot-token
GYMBOT_MONGO_URI=mongodb://gymbot:changeme@localhost:27017/
GYMBOT_MONGO_DATABASE=gym-bot
GYMBOT_DEFAULT_CONFIG_PATH=training_config_default.yaml
GYMBOT_EXCLUDED_WORKOUTS=["home"]

# If set, this user's config is rewritten from the YAML on every startup.
# Workflow: edit training_config_default.yaml → restart bot → new config active.
# Leave unset for pure multi-user mode (seed-on-first-run, no sync).
#GYMBOT_OWNER_USER_ID=123456789

# --- Mongo container credentials (read by docker-compose.yml) ---
# Must match the user/pass embedded in GYMBOT_MONGO_URI above.
MONGO_ROOT_USER=gymbot
MONGO_ROOT_PASSWORD=changeme
